{
  "name": "flutter-tilt-book",
  "version": "1.0.12",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate-search-data && next dev -p 3001",
    "build": "npm run generate-search-data && next build",
    "start": "next start -p 3001",
    "lint": "npx eslint . --quiet",
    "lint:fix": "npx eslint . --fix --quiet",
    "format": "npx prettier --write . --log-level warn",
    "format:check": "npx prettier --check .",
    "clean": "npm run lint:fix && npm run format && npm run format:check",
    "update": "npx npm-check-updates -u && npm install && npm run clean",
    "prepare": "cd .. && husky flutter_tilt_book/.husky",
    "generate-search-data": "tsx scripts/generate-search-data.ts",
    "build-flutter-tilt-example": "bash tools/build-flutter-tilt-example.sh"
  },
